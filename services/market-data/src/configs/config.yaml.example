# Local development example — export these env vars before starting the service:
#
#   export MYSQL_USER=root MYSQL_PASSWORD=root MYSQL_HOST=127.0.0.1
#   export MYSQL_PORT=3306 MYSQL_DB=market_data_db
#   export REDIS_ADDR=127.0.0.1:6379 REDIS_PASSWORD=
#   export KAFKA_BROKER=127.0.0.1:9092
#   export POLYGON_API_KEY=your-polygon-key-here
#   export HKEX_ENDPOINT=https://fake-hkex-feed.example.com
#   export OTLP_ENDPOINT=127.0.0.1:4317

server:
  http:
    addr: "0.0.0.0:8080"
  grpc:
    addr: "0.0.0.0:9090"
  ws:
    addr: "0.0.0.0:8081"

data:
  mysql:
    dsn: "${MYSQL_USER}:${MYSQL_PASSWORD}@tcp(${MYSQL_HOST}:${MYSQL_PORT})/${MYSQL_DB}?parseTime=true&loc=UTC&time_zone=%27%2B00%3A00%27&charset=utf8mb4"
  redis:
    addr: "${REDIS_ADDR}"
    password: "${REDIS_PASSWORD}"
    db: 0

kafka:
  brokers:
    - "${KAFKA_BROKER}"
  dlq_topic: "market-data.dlq"

polygon:
  api_key: "${POLYGON_API_KEY}"
  base_url: "https://api.polygon.io"
  symbols:
    - "AAPL"
    - "MSFT"
    - "GOOGL"
    - "TSLA"
    - "NVDA"

hkex:
  endpoint: "${HKEX_ENDPOINT}"

observability:
  otlp_endpoint: "${OTLP_ENDPOINT}"
